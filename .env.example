# KrishiVed Environment Variables Example
# Copy this file to .env in the root directory and update the values.

# Mandi API (Agmarknet/data.gov.in proxy settings)
REACT_APP_AGMARKNET_API_KEY=YOUR_AGMARKNET_API_KEY
REACT_APP_AGMARKNET_ENDPOINT=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# Weather API (OpenWeatherMap - optional, Open-Meteo is used by default)
REACT_APP_WEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# Dashboard Auto-refresh Interval in minutes
REACT_APP_AUTOREFRESH_MIN=5

# Gemini API Key for online chatbot mode
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
